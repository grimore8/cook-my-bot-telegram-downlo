# Telegram (required)
TELEGRAM_BOT_TOKEN=

# Optional controls (safe defaults are used if missing)
MAX_UPLOAD_MB=50
COOLDOWN_SEC=20
CONCURRENCY=2
PORT=3000

# Optional: max runtime per job (in ms)
JOB_TIMEOUT_MS=720000

# Optional: tmp root (default ./tmp)
TMP_ROOT=./tmp

# Auto-synced env keys detected from process.env usage:
AI_DEBUG=
AI_MODEL=
AI_TIMEOUT_MS=
COOKMYBOTS_AI_ENDPOINT=
COOKMYBOTS_AI_KEY=
MONGODB_URI=
NATURAL_CHAT_GROUP_REQUIRE_MENTION=
NATURAL_CHAT_MODE=
WEB3_CHAT_MODE=

